# vim: filetype=ini
# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
confirm-close-surface = false

# don't show an overlay when resizing a window
resize-overlay = never

window-theme = auto

# -----------------------------------------------------------------------------
# Theme & UI
# -----------------------------------------------------------------------------
theme = light:TokyoNight Day,dark:TokyoNight Moon
window-padding-x = 0
window-padding-y = 0

macos-titlebar-style = hidden
window-decoration = false
auto-update-channel = tip
bell-features = border

unfocused-split-opacity = 0.95
mouse-hide-while-typing = true
cursor-style-blink = false
cursor-style = block
adjust-cursor-thickness = 300%

# -----------------------------------------------------------------------------
# Fonts
# -----------------------------------------------------------------------------
font-family = "GeistMono Nerd Font Mono"
font-size = 16
# font-variation-bold = "wght=500"
# adjust-cell-width = "-10%"
# font-thicken = 1

# -----------------------------------------------------------------------------
# Keybindings
# -----------------------------------------------------------------------------
# Use the macOS Option key as Alt
macos-option-as-alt = true

# Unbind some defaults
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = ctrl+space=unbind

# Tmux window management (C-Space prefix = \x00)
keybind = cmd+t=text:\x00c
keybind = cmd+w=text:\x00x
keybind = cmd+r=text:\x00r

# Tmux session management
keybind = cmd+k=text:\x00T
keybind = cmd+s=text:\x00L

# Claude AI pane
keybind = cmd+a=text:\x00a

# Reload tmux config
keybind = cmd+shift+r=text:\x00.

